pkgname=zotero-bin
pkgver=7.0.24  # 替换为实际版本
pkgrel=1
pkgdesc="linux for $pkgname"
arch=('x86_64')  # 根据架构修改
url="https://www.zotero.org/download"
license=('AGPL3')
depends=('dbus-glib' 'gtk3' 'nss' 'libxt')

provides=('zotero')
conflicts=('zotero')


# sha256sums=('f727308716741cf9746b92047b890c3f76c4b8b010bc5ed21b5cdb1be85e21e9')
sha256sums=('SKIP')
sha256sums_x86_64=('a9b78cb2ba163d29036ee7ec8b7c88ebae4370a3fbf5255d74949069ddb5d6a0')
source=("zotero.desktop")
source_x86_64=("Zotero-${pkgver}_linux_$CARCH.tar.bz2::https://www.zotero.org/download/client/dl?channel=release&platform=linux-$CARCH&version=${pkgver}")



package() {
  # 创建安装目录 /opt/zotero
  install -dDm755 "$pkgdir"/opt/zotero
  mv "$srcdir"/Zotero_linux-$CARCH/* "$pkgdir"/opt/zotero

  # 创建符号链接到 /usr/bin
  install -dDm755 "$pkgdir/usr/bin"
  ln -sf /opt/zotero/zotero "$pkgdir"/usr/bin/zotero

  # 安装桌面文件
  install -Dm644 "$srcdir"/zotero.desktop "$pkgdir"/usr/share/applications/zotero.desktop

  # 复制图标文件
  install -Dm644 "$pkgdir"/opt/zotero/icons/icon32.png "$pkgdir"/usr/share/icons/hicolor/32x32/apps/zotero.png
  install -Dm644 "$pkgdir"/opt/zotero/icons/icon64.png "$pkgdir"/usr/share/icons/hicolor/64x64/apps/zotero.png
  install -Dm644 "$pkgdir"/opt/zotero/icons/icon128.png "$pkgdir"/usr/share/icons/hicolor/128x128/apps/zotero.png
  install -Dm644 "$pkgdir"/opt/zotero/icons/symbolic.svg "$pkgdir"/usr/share/icons/hicolor/symbolic/apps/zotero-symbolic.svg

  # 修改启动脚本
  sed -i -r 's/^("\$CALLDIR\/zotero-bin" -app "\$CALLDIR\/app\/application.ini" "\$@")/exec \1/' "$pkgdir"/opt/zotero/zotero
}
